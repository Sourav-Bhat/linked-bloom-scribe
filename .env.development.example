# Dev environment — copy to `.env.development` and fill with your DEV Firebase project values.
# Loaded automatically by `npm run dev` and by the local Docker build (development mode).
# These are public client-side Firebase config values; keep the file gitignored anyway.
VITE_APP_ENV="development"
VITE_FIREBASE_API_KEY="your-dev-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-dev-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-dev-project"
VITE_FIREBASE_STORAGE_BUCKET="your-dev-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-dev-sender-id"
VITE_FIREBASE_APP_ID="your-dev-app-id"
VITE_CLOUD_FUNCTIONS_BASE_URL="https://us-central1-your-dev-project.cloudfunctions.net"
