# Dev environment — copy to `.env.development` (gitignored). Used by `npm run dev`.
#
# Local dev runs entirely against the Firebase Emulator Suite (Auth, Firestore,
# Storage, Functions all local) — no cloud project, no separate Firebase project.
# A "demo-" project id keeps the Firebase tooling in emulator-only mode and
# guarantees it never contacts real cloud services.
VITE_APP_ENV="development"
VITE_USE_EMULATORS="true"

# With emulators, these don't point at a real project — any non-empty values
# work. Keep the demo- project id so tooling stays emulator-only.
VITE_FIREBASE_API_KEY="demo-key"
VITE_FIREBASE_AUTH_DOMAIN="localhost"
VITE_FIREBASE_PROJECT_ID="demo-linkedbloom"
VITE_FIREBASE_STORAGE_BUCKET="demo-linkedbloom.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="demo-app-id"

# Functions are served by the local Functions emulator (see firebase.json ports).
VITE_CLOUD_FUNCTIONS_BASE_URL="http://localhost:5001/demo-linkedbloom/us-central1"
