# Copy this file to .env and fill in your values
# Firebase project config — all values are public/safe (found in Firebase console > Project settings)
VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"

# Cloud Function base URL — set after running: firebase deploy --only functions
# Format: https://us-central1-<project-id>.cloudfunctions.net
VITE_CLOUD_FUNCTIONS_BASE_URL="https://us-central1-your-project-id.cloudfunctions.net"
