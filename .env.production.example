# Production environment — you normally do NOT create this file locally.
# CI (.github/workflows/deploy.yml) generates `.env.production` at build time from
# the GitHub Actions repo secrets, and `npm run build` (production mode) reads it.
# Listed here only to document the keys CI provides.
VITE_APP_ENV="production"
VITE_FIREBASE_API_KEY="<from secret VITE_FIREBASE_API_KEY>"
VITE_FIREBASE_AUTH_DOMAIN="<from secret VITE_FIREBASE_AUTH_DOMAIN>"
VITE_FIREBASE_PROJECT_ID="<from secret VITE_FIREBASE_PROJECT_ID>"
VITE_FIREBASE_STORAGE_BUCKET="<from secret VITE_FIREBASE_STORAGE_BUCKET>"
VITE_FIREBASE_MESSAGING_SENDER_ID="<from secret VITE_FIREBASE_MESSAGING_SENDER_ID>"
VITE_FIREBASE_APP_ID="<from secret VITE_FIREBASE_APP_ID>"
VITE_CLOUD_FUNCTIONS_BASE_URL="https://us-central1-contentmanager-ed707.cloudfunctions.net"
