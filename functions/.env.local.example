# Functions emulator config — copy to `functions/.env.local` (gitignored).
# Loaded by the Firebase Functions emulator into the functions' process.env.
#
# Vertex AI (Gemini) can't be emulated, so when functions run locally they call
# the REAL Vertex AI. These two vars let that work while all app data stays in
# the local emulators:
#
#   VERTEX_PROJECT  — a real GCP project to run Gemini inference in (billing only;
#                     no app data is stored there). Reuse your existing project.
#   GOOGLE_APPLICATION_CREDENTIALS — absolute path to a service-account key that
#                     has the "Vertex AI User" role on VERTEX_PROJECT.
VERTEX_PROJECT="contentmanager-ed707"
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/your-service-account-key.json"

# Langfuse observability (optional) — DEV project keys. Tracing is a no-op if
# these are absent. Prod uses a separate Langfuse project via GitHub secrets.
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_BASE_URL="https://cloud.langfuse.com"

# Closed-beta access gate
#   ADMIN_EMAIL — where "new signup" notifications go (Trigger Email extension).
#   ADMIN_UIDS  — comma-separated uids allowed to call setUserAccess.
ADMIN_EMAIL="you@example.com"
ADMIN_UIDS=""
