rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Uploads belong to onboarding/app flows that only approved users reach.
    match /admiredPosts/{uid}/{filename} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid
        && request.auth.token.approved == true;
    }
  }
}
